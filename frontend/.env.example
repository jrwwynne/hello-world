# Copy this file to .env and fill in the values from Terraform outputs.
# Run: terraform -chdir=infra/environments/dev output
# These values are injected at build time by Vite and are NOT secret.

# API Gateway invoke URL (e.g. https://abc123.execute-api.ap-southeast-2.amazonaws.com/dev)
VITE_API_URL=https://REPLACE_ME.execute-api.ap-southeast-2.amazonaws.com/dev

# Cognito region
VITE_COGNITO_REGION=ap-southeast-2

# From: terraform output cognito_user_pool_id
VITE_COGNITO_USER_POOL_ID=ap-southeast-2_XXXXXXXXX

# From: terraform output cognito_client_id
VITE_COGNITO_CLIENT_ID=REPLACE_ME

# From: terraform output cognito_hosted_ui_domain
# Format: your-app-dev.auth.ap-southeast-2.amazoncognito.com
VITE_COGNITO_HOSTED_UI_DOMAIN=REPLACE_ME.auth.ap-southeast-2.amazoncognito.com

# The URL this app is served from. Used as the OAuth redirect URI.
# For local dev use http://localhost:5173
# For deployed environments use the CloudFront URL (terraform output frontend_url)
VITE_COGNITO_REDIRECT_URI=http://localhost:5173
