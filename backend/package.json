{
  "name": "platform-backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@aws-sdk/*",
    "package": "cd dist && zip -r ../function.zip index.js",
    "build:package": "npm run build && npm run package",
    "lint": "eslint . --ext .ts --max-warnings 0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.490.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "esbuild": "^0.19.10",
    "eslint": "^8.55.0",
    "typescript": "^5.3.3"
  }
}
