# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored — do not commit real values.

# ── Required ──────────────────────────────────────────────────────────────────

# Short name for your project, used in resource naming (lowercase, no spaces).
project_name = "REPLACE_ME"

# GitHub organisation or username.
github_org = "REPLACE_ME"

# GitHub repository name (without org prefix).
github_repo = "REPLACE_ME"

# ── Cognito callback URLs ─────────────────────────────────────────────────────
#
# Step 1 bootstrap: keep localhost only.
# Step 2: add the CloudFront URL from `terraform output frontend_url`.
#
# cognito_callback_urls = [
#   "http://localhost:5173",
#   "https://REPLACE_ME.cloudfront.net",
# ]
#
# cognito_logout_urls = [
#   "http://localhost:5173",
#   "https://REPLACE_ME.cloudfront.net",
# ]

cognito_callback_urls = ["http://localhost:5173"]
cognito_logout_urls   = ["http://localhost:5173"]

# ── Optional overrides ────────────────────────────────────────────────────────

# aws_region       = "ap-southeast-2"
# bedrock_model_id = "anthropic.claude-3-haiku-20240307-v1:0"

# Set to false if the GitHub OIDC provider already exists in this AWS account.
# create_oidc_provider = true

# Note: Lambda function code is managed by the backend CI/CD workflow
# (aws lambda update-function-code), not by Terraform.  No ZIP path is needed here.
